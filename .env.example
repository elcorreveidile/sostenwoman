# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/sostenwoman"

# NextAuth — obligatorio para que funcione la autenticación
# Genera con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aleatorio-muy-largo"

# Resend — para enviar magic links por email
# Sin esta clave, los magic links se imprimen en la terminal (modo dev)
# Obtén tu clave en: https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@sostenwoman.com"

# Stripe — para el checkout y pagos
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"

# Cloudinary — para subir y gestionar imágenes de productos
# Obtén tus credenciales en: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
